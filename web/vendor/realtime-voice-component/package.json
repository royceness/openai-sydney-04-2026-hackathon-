{
  "name": "realtime-voice-component",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "React voice controls for browser apps using OpenAI Realtime.",
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openai/realtime-voice-component.git"
  },
  "homepage": "https://github.com/openai/realtime-voice-component#readme",
  "bugs": {
    "url": "https://github.com/openai/realtime-voice-component/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist/index.cjs",
    "dist/index.d.cts",
    "dist/index.d.ts",
    "dist/index.js",
    "dist/styles.css",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "keywords": ["openai", "react", "realtime", "voice", "webrtc"],
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0",
    "zod": "^4.3.6"
  }
}
